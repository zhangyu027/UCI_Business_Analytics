      <layout _.fcp.SchemaViewerObjectModel.false...dim-percentage='0.5' _.fcp.SchemaViewerObjectModel.false...measure-percentage='0.4' dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='shape' field='[none:diagnosis_short_description:nk]' type='shape'>
            <map to='asterisk'>
              <bucket>&quot;PROLONGED PREGNANCY&quot;</bucket>
            </map>
            <map to='circle'>
              <bucket>&quot;2ND-DEG PERIN LACER DUR DELIV&quot;</bucket>
            </map>
            <map to='diamond'>
              <bucket>&quot;OTH SPEC COMPLICATIONS OF PREG&quot;</bucket>
            </map>
            <map to='down-triangle'>
              <bucket>&quot;ABNORMAL GLUCOSE TOLERANCE&quot;</bucket>
            </map>
            <map to='left-triangle'>
              <bucket>&quot;DEEP TRANS ARR PERSIS OP/OA POS&quot;</bucket>
            </map>
            <map to='plus'>
              <bucket>&quot;THREATENED LABOUR&quot;</bucket>
            </map>
            <map to='right-triangle'>
              <bucket>&quot;PROLONGED SECOND STAGE LABOR&quot;</bucket>
            </map>
            <map to='square'>
              <bucket>&quot;1ST-DEG PERIN LACER DUR DELIV&quot;</bucket>
            </map>
            <map to='times'>
              <bucket>&quot;OTHER &amp; UNSPEC UTERINE INERTIA&quot;</bucket>
            </map>
            <map to='triangle'>
              <bucket>&quot;MILD OR UNSPEC PRE-ECLAMPSIA&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:procedure_description:nk]' type='palette'>
            <map to='#499894'>
              <bucket>&quot;LOW FORCEPS NO EPISIOTOMY&quot;</bucket>
            </map>
            <map to='#4e79a7'>
              <bucket>&quot;ABSCESS INCISION&quot;</bucket>
            </map>
            <map to='#4e79a7'>
              <bucket>&quot;SPHINCTER ANI&quot;</bucket>
            </map>
            <map to='#59a14f'>
              <bucket>&quot;FOLLOWING DELIVERY ABORTION&quot;</bucket>
            </map>
            <map to='#59a14f'>
              <bucket>&quot;WITH EPISIOTOMY&quot;</bucket>
            </map>
            <map to='#79706e'>
              <bucket>&quot;OTHER CESAREAN SECTION&quot;</bucket>
            </map>
            <map to='#86bcb6'>
              <bucket>&quot;LOW FORCEPS WITH EPISIOTOMY&quot;</bucket>
            </map>
            <map to='#8cd17d'>
              <bucket>&quot;FORCEPS ROTATION FETAL HEAD&quot;</bucket>
