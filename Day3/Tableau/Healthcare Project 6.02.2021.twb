      <aliases enabled='yes' />
      <column caption='Average Length of Stay' datatype='real' name='[Calculation_1288522127402070016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([length_of_stay])/COUNT([procedure_description])' />
      </column>
      <column caption='Encounter Count' datatype='integer' name='[Calculation_1288522127735889924]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([encounter_counter])' />
      </column>
      <column caption='Admission Date' datatype='date' name='[Calculation_2331879499095113729]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE(YEAR([discharge_date]), MONTH([discharge_date]),DAY([discharge_date])-[length_of_stay])' />
      </column>
      <column caption='Physician Count' datatype='integer' name='[Calculation_2331879499096010754]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([physician_name])' />
      </column>
      <column caption='Repetetive Visits' datatype='integer' name='[Calculation_2331879499099279363]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNTD(STR([longitude])+&quot;-&quot;+STR([latitude]))' />
      </column>
      <column caption='Day Name' datatype='string' name='[Calculation_2331879499117182980]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [day_in_week]=1&#10;THEN &quot;Monday&quot;&#10;ELSEIF [day_in_week]=2&#10;THEN &quot;Tuesday&quot;&#10;ELSEIF [day_in_week]=3&#10;THEN &quot;Wednesday&quot;&#10;ELSEIF [day_in_week]=4&#10;THEN &quot;Thursday&quot;&#10;ELSEIF [day_in_week]=5&#10;THEN &quot;Friday&quot;&#10;ELSEIF [day_in_week]=6&#10;THEN &quot;Saturday&quot;&#10;ELSEIF [day_in_week]=7&#10;THEN &quot;Sunday&quot;&#10;END' />
      </column>
      <column caption='Sum of records' datatype='integer' name='[Calculation_559009358264393728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([encounter_number])' />
      </column>
      <column caption='Unique Procedure Count' datatype='integer' name='[Calculation_641481526101360640]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([procedure_description])' />
      </column>
      <column caption='Average Length of Stay/Diagnosis' datatype='real' name='[Calculation_641481526110756865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([length_of_stay])/COUNT([diagnosis_short_description])' />
      </column>
